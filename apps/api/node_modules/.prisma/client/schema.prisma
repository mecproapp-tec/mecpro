generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                         String                  @id @default(uuid())
  name                       String
  documentType               String
  documentNumber             String                  @unique
  cep                        String
  address                    String
  email                      String                  @unique
  phone                      String
  logoUrl                    String?
  status                     TenantStatus            @default(ACTIVE)
  trialEndsAt                DateTime?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  paymentStatus              String?                 @default("pending")
  subscriptionId             String?                 @unique
  complement                 String?
  number                     String?
  registrationToken          String?
  registrationTokenExpiresAt DateTime?
  appointments               Appointment[]
  Budget                     Budget[]
  clients                    Client[]
  contactMessages            ContactMessage[]
  estimates                  Estimate[]
  invoices                   Invoice[]
  notifications              Notification[]
  payments                   Payment[]
  pendingSubscriptions       PendingSubscription[]
  publicShares               PublicShare[]
  scheduledNotifications     ScheduledNotification[]
  subscriptions              Subscription[]
  users                      User[]
  whatsappLogs               WhatsappLog[]

  @@index([status])
  @@index([email])
  @@index([documentNumber])
  @@index([paymentStatus])
}

model User {
  name          String
  email         String         @unique
  password      String
  role          UserRole       @default(OWNER)
  tenantId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  id            Int            @id @default(autoincrement())
  status        UserStatus     @default(ACTIVE)
  tokenVersion  Int            @default(0)
  paymentStatus String?        @default("pending")
  clients       Client[]
  refreshTokens RefreshToken[]
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions      UserSession[]

  @@index([email])
  @@index([tenantId])
}

model Client {
  id           Int           @id @default(autoincrement())
  tenantId     String
  userId       Int?
  name         String
  phone        String
  vehicle      String
  plate        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  address      String?
  document     String?
  deletedAt    DateTime?
  status       ClientStatus  @default(ACTIVE)
  appointments Appointment[]
  Budget       Budget[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])
  estimates    Estimate[]
  invoices     Invoice[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@index([tenantId, phone])
  @@index([userId])
  @@index([createdAt])
}

model Appointment {
  tenantId      String
  createdAt     DateTime       @default(now())
  clientId      Int
  comment       String?
  date          DateTime
  id            Int            @id @default(autoincrement())
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([tenantId, date])
  @@index([clientId])
  @@index([date])
}

model Estimate {
  tenantId          String
  total             Decimal        @db.Decimal(10, 2)
  status            EstimateStatus @default(DRAFT)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  clientId          Int
  id                Int            @id @default(autoincrement())
  date              DateTime
  shareToken        String?        @unique
  shareTokenExpires DateTime?
  pdfGeneratedAt    DateTime?      @map("pdf_generated_at")
  pdfStatus         String?        @default("pending") @map("pdf_status")
  pdfUrl            String?        @map("pdf_url")
  pdfKey            String?        @map("pdf_key")
  deletedAt         DateTime?
  paymentMethod     PaymentMethod?
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             EstimateItem[]
  invoice           Invoice?

  @@index([tenantId, status, createdAt])
  @@index([tenantId, clientId])
  @@index([deletedAt])
  @@index([shareToken])
  @@index([pdfStatus])
}

model EstimateItem {
  description String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  id          Int      @id @default(autoincrement())
  estimateId  Int
  issPercent  Float?
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model Invoice {
  tenantId          String
  total             Decimal        @db.Decimal(10, 2)
  status            InvoiceStatus  @default(PENDING)
  createdAt         DateTime       @default(now())
  clientId          Int
  number            String         @unique
  id                Int            @id @default(autoincrement())
  estimateId        Int?           @unique
  shareToken        String?        @unique
  shareTokenExpires DateTime?
  pdfGeneratedAt    DateTime?      @map("pdf_generated_at")
  pdfStatus         String?        @default("pending") @map("pdf_status")
  pdfUrl            String?        @map("pdf_url")
  pdfKey            String?        @map("pdf_key")
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  paymentMethod     PaymentMethod?
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  estimate          Estimate?      @relation(fields: [estimateId], references: [id])
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             InvoiceItem[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, number])
  @@index([deletedAt])
  @@index([shareToken])
  @@index([pdfStatus])
}

model InvoiceItem {
  description String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  issPercent  Float?
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Subscription {
  id                    String             @id @default(uuid())
  tenantId              String
  planName              String
  price                 Decimal            @db.Decimal(10, 2)
  status                SubscriptionStatus
  gateway               String
  gatewaySubscriptionId String?
  startDate             DateTime
  endDate               DateTime?
  createdAt             DateTime           @default(now())
  payments              Payment[]
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([gatewaySubscriptionId])
  @@index([endDate])
}

model Payment {
  id               String        @id @default(uuid())
  tenantId         String
  subscriptionId   String?
  amount           Decimal       @db.Decimal(10, 2)
  status           PaymentStatus
  gatewayPaymentId String?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
  @@index([tenantId, status])
}

model PendingSubscription {
  id             String   @id @default(uuid())
  email          String   @unique
  subscriptionId String?
  planId         String
  trialEndsAt    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  status         String   @default("pending")
  tenantId       String?
  officeName     String?
  documentType   String?
  documentNumber String?
  address        String?
  cep            String?
  phone          String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([email, status])
  @@index([trialEndsAt])
}

model PublicShare {
  id         String    @id @default(cuid())
  token      String    @unique
  type       ShareType
  resourceId Int
  tenantId   String
  pdfUrl     String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenantId])
  @@index([type, resourceId])
  @@index([expiresAt])
}

model RefreshToken {
  id           Int      @id @default(autoincrement())
  userId       Int
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  sessionToken String?
  tokenHash    String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionToken])
  @@index([expiresAt])
}

model UserSession {
  id           Int       @id @default(autoincrement())
  userId       Int
  sessionToken String    @unique
  ipAddress    String?
  userAgent    String?
  lastActivity DateTime  @default(now())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@index([lastActivity])
}

model Notification {
  tenantId      String?
  title         String
  message       String
  isGlobal      Boolean      @default(false)
  read          Boolean      @default(false)
  createdAt     DateTime     @default(now())
  id            Int          @id @default(autoincrement())
  appointmentId Int?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  tenant        Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([read, createdAt])
  @@index([appointmentId])
}

model ScheduledNotification {
  id        String   @id @default(uuid())
  tenantId  String?
  title     String
  message   String
  target    String
  schedule  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([schedule, sent])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  tenantId  String?
  userEmail String?
  userName  String?
  message   String
  status    String   @default("pending")
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([createdAt])
}

model WhatsappLog {
  id           String    @id @default(uuid())
  tenantId     String
  type         String // estimate, invoice
  resourceId   Int
  phone        String
  status       String // SENT, FAILED, DELIVERED, READ
  messageId    String?
  errorMessage String?
  sentAt       DateTime  @default(now())
  deliveredAt  DateTime?
  readAt       DateTime?
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([sentAt])
}

model Budget {
  id         Int          @id @default(autoincrement())
  clientId   Int
  tenantId   String
  total      Decimal      @db.Decimal(10, 2)
  status     String
  createdAt  DateTime     @default(now())
  deletedAt  DateTime?
  Client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  Tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  BudgetItem BudgetItem[]

  @@index([deletedAt])
  @@index([tenantId, status, createdAt])
}

model BudgetItem {
  id          Int     @id @default(autoincrement())
  budgetId    Int
  description String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  issPercent  Float?
  Budget      Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model SuperAdmin {
  id        String   @id
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@index([email])
}

enum TenantStatus {
  ACTIVE
  BLOCKED
  CANCELED
}

enum UserRole {
  OWNER
  ADMIN
  // SUPER_ADMIN removido – agora apenas a model SuperAdmin representa o super administrador
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ClientStatus {
  ACTIVE
  BLOCKED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  CONVERTED
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELED
}

enum ShareType {
  ESTIMATE
  INVOICE
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  PIX
}
