generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ///////////////// CONTACT MESSAGES (FAQ) ////////////////////
model ContactMessage {
  id        Int      @id @default(autoincrement())
  tenantId  String?
  userEmail String?
  userName  String?
  message   String
  status    String   @default("pending")
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}

/// ///////////////// ASSINATURAS PENDENTES (antes do cadastro) ////////////////////
model PendingSubscription {
  id             String   @id @default(uuid())
  email          String   @unique
  subscriptionId String?
  planId         String
  trialEndsAt    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  status         String   @default("pending")
  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([email, status])
  @@index([status])
}

/// ///////////////// TENANT (Oficina) ////////////////////
model Tenant {
  id                     String                  @id @default(uuid())
  name                   String
  documentType           String
  documentNumber         String                  @unique
  cep                    String
  address                String
  email                  String                  @unique
  phone                  String
  logoUrl                String?
  status                 TenantStatus            @default(ACTIVE)
  trialEndsAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  paymentStatus          String?                 @default("pending")
  subscriptionId         String?                 @unique
  appointments           Appointment[]
  clients                Client[]
  contactMessages        ContactMessage[]
  estimates              Estimate[]
  invoices               Invoice[]
  notifications          Notification[]
  payments               Payment[]
  scheduledNotifications ScheduledNotification[]
  subscriptions          Subscription[]
  users                  User[]
  pendingSubscriptions   PendingSubscription[]

  publicShares           PublicShare[] 

  @@index([status])
  @@index([email])
  @@index([documentNumber])
}
/// ///////////////// USUÁRIOS (proprietários e admins da oficina) ////////////////////
model User {
  name          String
  email         String         @unique
  password      String
  role          UserRole       @default(OWNER)
  tenantId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  id            Int            @id @default(autoincrement())
  clients       Client[]
  refreshTokens RefreshToken[]
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions      UserSession[]

  @@index([email])
  @@index([tenantId])
}

/// ///////////////// SUPER ADMIN (opcional) ////////////////////
model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

/// ///////////////// SUBSCRIPTIONS ////////////////////
model Subscription {
  id                    String             @id @default(uuid())
  tenantId              String
  planName              String
  price                 Float
  status                SubscriptionStatus
  gateway               String
  gatewaySubscriptionId String?
  startDate             DateTime
  endDate               DateTime?
  createdAt             DateTime           @default(now())
  payments              Payment[]
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([gatewaySubscriptionId])
}

/// ///////////////// PAYMENTS ////////////////////
model Payment {
  id               String        @id @default(uuid())
  tenantId         String
  subscriptionId   String?
  amount           Float
  status           PaymentStatus
  gatewayPaymentId String?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
}

/// ///////////////// CLIENTES ////////////////////
model Client {
  id           Int           @id @default(autoincrement())
  tenantId     String
  userId       Int?
  name         String
  phone        String
  vehicle      String
  plate        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  address      String?
  document     String?
  appointments Appointment[]
  budgets      Budget[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])
  estimates    Estimate[]
  invoices     Invoice[]

  @@index([tenantId])
  @@index([userId])
  @@index([phone])
}

/// ///////////////// REFRESH TOKENS ////////////////////
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

/// ///////////////// SESSÕES ATIVAS DOS USUÁRIOS ////////////////////
model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int
  sessionToken String   @unique
  ipAddress    String?
  userAgent    String?
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

/// ///////////////// AGENDAMENTOS ////////////////////
model Appointment {
  tenantId      String
  createdAt     DateTime       @default(now())
  clientId      Int
  comment       String?
  date          DateTime
  id            Int            @id @default(autoincrement())
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([tenantId])
  @@index([clientId])
  @@index([date])
}

/// ///////////////// ORÇAMENTOS ////////////////////
model Estimate {
  tenantId          String
  total             Float
  status            EstimateStatus @default(DRAFT)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  clientId          Int
  id                Int            @id @default(autoincrement())
  date              DateTime
  shareToken        String?        @unique
  shareTokenExpires DateTime?
  pdfGeneratedAt    DateTime?      @map("pdf_generated_at")
  pdfStatus         String?        @default("pending") @map("pdf_status")
  pdfUrl            String?        @map("pdf_url")
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             EstimateItem[]
  invoice           Invoice?

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([pdfUrl])
  @@index([pdfStatus])
  @@index([tenantId, pdfStatus])
}

model EstimateItem {
  description String
  quantity    Int
  price       Float
  total       Float
  id          Int      @id @default(autoincrement())
  estimateId  Int
  issPercent  Float?
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@unique([estimateId, id])
  @@index([estimateId])
}

/// ///////////////// ORÇAMENTOS (versão antiga, manter compatibilidade) ////////////////////
model Budget {
  id        Int      @id @default(autoincrement())
  clientId  Int
  tenantId  String
  items     String
  total     Float
  status    String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
}

/// ///////////////// FATURAS ////////////////////
model Invoice {
  tenantId          String
  total             Float
  status            InvoiceStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  clientId          Int
  number            String        @unique
  id                Int           @id @default(autoincrement())
  estimateId        Int?          @unique
  shareToken        String?       @unique
  shareTokenExpires DateTime?
  pdfGeneratedAt    DateTime?     @map("pdf_generated_at")
  pdfStatus         String?       @default("pending") @map("pdf_status")
  pdfUrl            String?       @map("pdf_url")
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  estimate          Estimate?     @relation(fields: [estimateId], references: [id])
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             InvoiceItem[]

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([number])
  @@index([pdfUrl])
  @@index([pdfStatus])
  @@index([tenantId, pdfStatus])
}

model InvoiceItem {
  description String
  quantity    Int
  price       Float
  total       Float
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  issPercent  Float?
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, id])
  @@index([invoiceId])
}

/// ///////////////// NOTIFICAÇÕES ////////////////////
model Notification {
  tenantId      String?
  title         String
  message       String
  isGlobal      Boolean      @default(false)
  read          Boolean      @default(false)
  createdAt     DateTime     @default(now())
  id            Int          @id @default(autoincrement())
  appointmentId Int?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  tenant        Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([appointmentId])
  @@index([read, createdAt])
}

/// ///////////////// NOTIFICAÇÕES AGENDADAS (para o admin) ////////////////////
model ScheduledNotification {
  id        String   @id @default(uuid())
  tenantId  String?
  title     String
  message   String
  target    String
  schedule  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([schedule, sent])
}

model PublicShare {
  id         String   @id @default(cuid())
  token      String   @unique
  type       ShareType
  resourceId Int
  tenantId   String

  pdfUrl     String
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenantId])
  @@index([type, resourceId])
}

/// ///////////////// ENUMS ////////////////////
enum TenantStatus {
  ACTIVE
  BLOCKED
  CANCELED
}

enum UserRole {
  OWNER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  CONVERTED
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELED
}

enum ShareType {
  ESTIMATE
  INVOICE
}