<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Fatura #{{invoiceNumber}}</title>

<style>
* {
  box-sizing: border-box;
}

body {
  font-family: 'Segoe UI', Arial, sans-serif;
  margin: 0;
  padding: 20px;
  background: #fff;
  color: #333;
}

.container {
  max-width: 1000px;
  margin: auto;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  overflow: hidden;
}

.content {
  padding: 30px;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2px solid #0077ff;
  padding-bottom: 20px;
  margin-bottom: 25px;
}

.logo img {
  max-height: 70px;
  max-width: 200px;
}

.company-info {
  text-align: right;
  font-size: 12px;
}

.company-info h2 {
  margin: 0;
  color: #0077ff;
}

.title {
  text-align: center;
  margin-bottom: 25px;
}

.title h1 {
  margin: 0;
  color: #0077ff;
}

.status {
  display: inline-block;
  margin-top: 8px;
  background: #e6f4ff;
  color: #0077ff;
  padding: 5px 15px;
  border-radius: 20px;
  font-size: 12px;
}

.box {
  background: #f9f9f9;
  padding: 15px;
  border-radius: 6px;
  margin-bottom: 20px;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 20px;
}

th {
  background: #f0f7ff;
  color: #0077ff;
  padding: 10px;
  text-align: left;
}

td {
  padding: 10px;
  border-bottom: 1px solid #eee;
}

.right {
  text-align: right;
}

.totals {
  margin-top: 20px;
  text-align: right;
}

.total {
  font-size: 18px;
  font-weight: bold;
  color: #0077ff;
}

.footer {
  margin-top: 40px;
  font-size: 11px;
  text-align: center;
  color: #888;
}
</style>
</head>

<body>
<div class="container">
<div class="content">

<div class="header">
  <div class="logo">
    {{#if logoUrl}}
      <img src="{{logoUrl}}" />
    {{/if}}
  </div>
  <div class="company-info">
    <h2>{{companyName}}</h2>
    <p>{{companyDocument}}</p>
    <p>{{companyPhone}}</p>
    <p>{{companyEmail}}</p>
  </div>
</div>

<div class="title">
  <h1>FATURA Nº {{invoiceNumber}}</h1>
  <div class="status">{{status}}</div>
</div>

<div class="box">
  <strong>Cliente</strong>
  <div class="grid">
    <p><b>Nome:</b> {{client.name}}</p>
    <p><b>Telefone:</b> {{client.phone}}</p>
    <p><b>Veículo:</b> {{client.vehicle}}</p>
    <p><b>Placa:</b> {{client.plate}}</p>
    <p><b>Documento:</b> {{client.document}}</p>
    <p><b>Endereço:</b> {{client.address}}</p>
  </div>
</div>

<div class="box">
  <p><b>Data:</b> {{issueDate}}</p>
  {{#if dueDate}}
  <p><b>Vencimento:</b> {{dueDate}}</p>
  {{/if}}
</div>

<table>
<thead>
<tr>
  <th>Descrição</th>
  <th class="right">Qtd</th>
  <th class="right">Unit</th>
  <th class="right">Total</th>
</tr>
</thead>

<tbody>
{{#each items}}
<tr>
  <td>{{description}}</td>
  <td class="right">{{quantity}}</td>
  <td class="right">{{unitPrice}}</td>
  <td class="right">{{total}}</td>
</tr>
{{/each}}
</tbody>
</table>

<div class="totals">
  <p>Subtotal: R$ {{subtotal}}</p>
  {{#if issValue}}
  <p>ISS: R$ {{issValue}}</p>
  {{/if}}
  <div class="total">TOTAL: R$ {{total}}</div>
</div>

<div class="footer">
  <p>{{companyName}}</p>
  <p>{{companyPhone}} | {{companyEmail}}</p>
</div>

</div>
</div>
</body>
</html>