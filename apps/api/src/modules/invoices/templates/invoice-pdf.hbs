<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Fatura #{{invoiceNumber}}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', 'Inter', system-ui, sans-serif;
    background: #f0f4f8;
    padding: 40px 20px;
  }
  .document {
    max-width: 1100px;
    margin: auto;
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  .header {
    background: linear-gradient(135deg, #0a0a0a 0%, #000000 100%);
    color: white;
    padding: 30px;
    text-align: center;
    border-bottom: 4px solid #00e5ff;
  }
  .header h1 {
    font-size: 28px;
    margin-bottom: 8px;
  }
  .body {
    padding: 30px;
  }
  .company-info {
    text-align: right;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 2px solid #e0e0e0;
  }
  .company-info h2 {
    color: #000000;  /* ← Nome da oficina em preto */
    margin-bottom: 5px;
  }
  .company-info p {
    color: #666;
    font-size: 12px;
    margin: 3px 0;
  }
  .client-box {
    background: linear-gradient(145deg, #f8f9fa 0%, #ffffff 100%);
    padding: 20px;
    border-radius: 16px;
    margin-bottom: 25px;
    border: 1px solid #e0e0e0;
  }
  .client-box h3 {
    background: #0a0a0a;
    color: #00e5ff;
    display: inline-block;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 14px;
    margin-bottom: 15px;
  }
  .client-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .client-item strong {
    min-width: 80px;
    display: inline-block;
  }
  .dates {
    background: #0a0a0a;
    color: #00e5ff;
    display: flex;
    justify-content: space-between;
    padding: 12px 20px;
    border-radius: 12px;
    margin-bottom: 25px;
    font-size: 13px;
    font-weight: 500;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 13px;
  }
  th {
    background: #0a0a0a;
    color: #00e5ff;
    padding: 12px;
    text-align: left;
  }
  td {
    padding: 12px;
    border-bottom: 1px solid #e0e0e0;
  }
  .text-right { text-align: right; }
  .text-center { text-align: center; }
  .totals {
    margin-top: 25px;
    text-align: right;
    border-top: 2px solid #e0e0e0;
    padding-top: 20px;
  }
  .total-geral {
    font-size: 22px;
    font-weight: bold;
    color: #00e5ff;
    background: #0a0a0a;
    display: inline-block;
    padding: 8px 24px;
    border-radius: 40px;
    margin-top: 10px;
  }
  .footer {
    background: #f8f9fa;
    padding: 20px;
    text-align: center;
    font-size: 11px;
    color: #888;
    border-top: 1px solid #e0e0e0;
  }
  .logo {
    max-width: 120px;
    max-height: 60px;
    object-fit: contain;
    margin-bottom: 10px;
  }
</style>
</head>
<body>
<div class="document">
  <div class="header">
    <h1>FATURA Nº {{invoiceNumber}}</h1>
  </div>
  
  <div class="body">
    <div class="company-info">
      {{#if companyLogo}}<img src="{{companyLogo}}" class="logo" alt="Logo">{{/if}}
      <h2>{{companyName}}</h2>
      <p>{{companyDocument}} | {{companyPhone}}</p>
      <p>{{companyEmail}}</p>
      <p>{{companyAddress}}</p>
    </div>
    
    <div class="client-box">
      <h3>DADOS DO CLIENTE</h3>
      <div class="client-grid">
        <div class="client-item"><strong>Nome:</strong> {{client.name}}</div>
        <div class="client-item"><strong>Telefone:</strong> {{client.phone}}</div>
        <div class="client-item"><strong>Veículo:</strong> {{client.vehicle}}</div>
        <div class="client-item"><strong>Placa:</strong> {{client.plate}}</div>
        <div class="client-item"><strong>Documento:</strong> {{client.document}}</div>
        <div class="client-item"><strong>Endereço:</strong> {{client.address}}</div>
      </div>
    </div>
    
    <div class="dates">
      <span>Emissão: {{issueDate}}</span>
      <span>Vencimento: {{dueDate}}</span>
    </div>
    
    <table>
      <thead>
        <tr>
          <th>Descrição</th>
          <th class="text-right">Qtde</th>
          <th class="text-right">Valor Unit.</th>
          <th class="text-center">ISS %</th>
          <th class="text-right">ISS Valor</th>
          <th class="text-right">Total c/ ISS</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr>
          <td>{{description}}</td>
          <td class="text-right">{{quantity}}</td>
          <td class="text-right">R$ {{unitPrice}}</td>
          <td class="text-center">{{issPercent}}%</td>
          <td class="text-right">R$ {{issValue}}</td>
          <td class="text-right">R$ {{totalWithIss}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    
    <div class="totals">
      <p>Subtotal (sem ISS): R$ {{subtotal}}</p>
      <p>Total de ISS: R$ {{totalIss}}</p>
      <div class="total-geral">TOTAL GERAL: R$ {{total}}</div>
    </div>
  </div>
  
  <div class="footer">
    <p>{{companyName}} - {{companyPhone}} | {{companyEmail}}</p>
    <p>Esta fatura é um documento oficial.</p>
  </div>
</div>
</body>
</html>